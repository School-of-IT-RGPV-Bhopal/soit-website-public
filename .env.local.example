# .env.local.example
# Copy this file to .env.local and replace placeholder values.

# Public site configuration
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CONTACT_EMAIL=soit@rgpv.ac.in
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com
NEXT_PUBLIC_CONTACT_PHONE_DISPLAY=+91 755 2678 844
NEXT_PUBLIC_CONTACT_PHONE_HREF=+917552678844
NEXT_PUBLIC_CONTACT_ADDRESS=School of Information Technology, RGPV Campus, Airport Road, Gandhi Nagar, Bhopal, Madhya Pradesh 462033
NEXT_PUBLIC_CONTACT_POSTAL_CODE=462033
NEXT_PUBLIC_CONTACT_MAPS_URL=https://maps.google.com/maps?q=School%20of%20Information%20Technology,%20RGPV%20Campus,%20Airport%20Road,%20Gandhi%20Nagar,%20Bhopal,%20Madhya%20Pradesh%20462033
NEXT_PUBLIC_CONTACT_MAPS_EMBED_URL=https://maps.google.com/maps?width=100%25&height=600&hl=en&q=School%20of%20Information%20Technology,%20RGPV%20Campus,%20Airport%20Road,%20Gandhi%20Nagar,%20Bhopal,%20Madhya%20Pradesh%20462033+(School%20Of%20Information%20Technology)&t=k&z=16&ie=UTF8&iwloc=B&output=embed
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/school/soitrgpv
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/soit_rgpv/

# Google Analytics 4 server configuration
# Get these from your Google Cloud service account JSON / GA4 setup.
GA_PROPERTY_ID=YOUR_GA_PROPERTY_ID
GOOGLE_PROJECT_ID=your-google-cloud-project-id
GOOGLE_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----"

# Alumni Google Sheets integration
GOOGLE_SPREADSHEET_ID=your-google-spreadsheet-id

# FAQ chat assistant
GEMINI_API_KEY=your-gemini-api-key
# Optional: defaults to gemini-1.5-flash if omitted
GEMINI_AGENT_MODEL=gemini-1.5-flash

# Note: GOOGLE_PRIVATE_KEY must use literal \n characters, not actual newlines.
# Example:
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...\n-----END PRIVATE KEY-----"
