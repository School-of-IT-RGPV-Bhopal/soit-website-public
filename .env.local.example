// .env.local - Add these to your environment variables

# Google Analytics 4 Configuration
# Get these from your Google Cloud Service Account JSON

GA_PROPERTY_ID=YOUR_GA_PROPERTY_ID
GOOGLE_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----"

# Note: The private key should include literal \n characters, not actual newlines
# Example:
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhk...\n-----END PRIVATE KEY-----"
